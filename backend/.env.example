# Prisma (Database)
DATABASE_URL="postgresql://postgres:docker@localhost:5432/bil?schema=public"

# Cache (Redis)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_DB="0"

# Auth (JWT)
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Upload (disco local via multer)
# Diretório onde os arquivos enviados são salvos. Opcional, padrão: "<raiz-do-backend>/uploads"
UPLOADS_DIRECTORY=""

PORT="3333"

# Observabilidade (OpenTelemetry)
# Nome exibido no trace/dashboard.
OTEL_SERVICE_NAME="bil-backend"
# Endpoint OTLP HTTP de um collector (ex.: Grafana Tempo, Jaeger, Azure Monitor).
# Se vazio, os traces são só impressos no console (útil em dev local).
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Segurança
# Origens permitidas para CORS, separadas por vírgula (ex.: "https://bil.jabil.com,https://staging.bil.jabil.com").
# Vazio = reflete a origem da requisição (permissivo, só para dev local).
CORS_ORIGIN=""

# Logging
# development | test | production
NODE_ENV="development"
# fatal | error | warn | info | debug | trace
LOG_LEVEL="info"
